# Production environment variables for GitHub Pages deployment
# 
# Important: VITE_API_URL should be the ROOT backend URL (without /api)
# Examples:
# VITE_API_URL=https://your-app.railway.app
# VITE_API_URL=https://your-app.onrender.com
# VITE_API_URL=https://your-custom-domain.com
#
# The /api part is added automatically in src/services/api.ts

VITE_API_URL=https://your-backend-service.railway.app
